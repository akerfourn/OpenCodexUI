{
  "name": "open-codex-ui",
  "version": "1.7.1",
  "description": "Electron desktop UI for the local Codex app-server.",
  "author": {
    "name": "Adrien Kerfourn",
    "email": "ak.sitecontact@gmail.com"
  },
  "homepage": "https://github.com/akerfourn/OpenCodexUI",
  "private": true,
  "packageManager": "npm@11.11.0",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --external:better-sqlite3 --outfile=dist/main/main.cjs && esbuild src/main/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main/preload.cjs",
    "build:renderer": "vite build",
    "dist": "npm run build && node scripts/dist.mjs",
    "dist:dir": "npm run build && node scripts/dist.mjs --dir",
    "rebuild:sqlite:electron": "electron-rebuild -f -w better-sqlite3 -v 32.3.3 -m ../..",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck"
  },
  "dependencies": {
    "@open-codex-ui/opencodex-cache": "file:../../packages/opencodex-cache",
    "@open-codex-ui/opencodex-core": "file:../../packages/opencodex-core",
    "@open-codex-ui/opencodex-protocol": "file:../../packages/opencodex-protocol",
    "@open-codex-ui/opencodex-ui": "file:../../packages/opencodex-ui",
    "better-sqlite3": "^12.9.0",
    "discord-rpc": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "32.3.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.23.0",
    "vite": "^5.3.5"
  }
}
