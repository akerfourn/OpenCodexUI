{
  "name": "open-codex-ui-electron-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "npm run build && electron dist/main/main.cjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main/main.cjs && esbuild src/main/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main/preload.cjs",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck"
  },
  "dependencies": {
    "@open-codex-ui/opencodex-core": "file:../../packages/opencodex-core",
    "@open-codex-ui/opencodex-protocol": "file:../../packages/opencodex-protocol",
    "@open-codex-ui/opencodex-ui": "file:../../packages/opencodex-ui",
    "electron": "^32.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.23.0",
    "vite": "^5.3.5"
  }
}
